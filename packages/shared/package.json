{
  "name": "shared",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "development": "./src/cli/index.ts",
      "default": "./dist/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:package": "pnpm exec tsx ../../tools/generate-schema-types.ts && tsdown --config tsdown.config.ts",
    "build:watch": "tsdown --config tsdown.config.ts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "clean:full": "rm -rf dist node_modules"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./cli": "./dist/cli/index.js",
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@ast-grep/napi": "^0.37.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@clack/prompts": "^1.0.1",
    "commander": "^12.1.0"
  }
}
