{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreWorkspaces": [
    "packages/shared",
    "packages/lakebase",
    "apps/**",
    "docs"
  ],
  "workspaces": {
    "packages/appkit": {},
    "packages/appkit-ui": {
      "ignoreDependencies": ["tailwindcss", "tw-animate-css"]
    }
  },
  "ignore": [
    "**/*.generated.ts",
    "**/*.example.tsx",
    "**/*.css",
    "template/**",
    "tools/**",
    "docs/**"
  ],
  "ignoreDependencies": ["json-schema-to-typescript"],
  "ignoreBinaries": ["tarball"]
}
